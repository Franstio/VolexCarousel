<ResourceDictionary xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                xmlns:models="using:VolexCarousel.Models"
        xmlns:controls="using:VolexCarousel.Controls">

  <!--
    Additional resources 
    Using Control Themes:
         https://docs.avaloniaui.net/docs/basics/user-interface/styling/control-themes
    Using Theme Variants:
         https://docs.avaloniaui.net/docs/guides/styles-and-resources/how-to-use-theme-variants
  -->
  
  <Design.PreviewWith>
    <StackPanel Width="400" Spacing="10">      
        <StackPanel Background="{DynamicResource SystemRegionBrush}">
          <controls:LogTemplateControl />
        </StackPanel>
    </StackPanel>
  </Design.PreviewWith>
 
  <ControlTheme x:Key="{x:Type controls:LogTemplateControl}" TargetType="controls:LogTemplateControl">
    <Setter Property="Template">
      <ControlTemplate>
          <Border>
                        <DataGrid x:Name="LogDataGrid"  Margin="20" ItemsSource="{TemplateBinding Logs}" 
          AutoGenerateColumns="False" ColumnWidth="*" IsReadOnly="True" 
          GridLinesVisibility="All"
          BorderThickness="1" BorderBrush="Gray">
              <DataGrid.Columns>

                  <DataGridTextColumn Header="Time" x:DataType="models:LogModel"  Binding="{Binding time}"/>
                  <DataGridTextColumn Header="Log"  x:DataType="models:LogModel" Binding="{Binding log}" />
              </DataGrid.Columns>
        </DataGrid>

          </Border>
      </ControlTemplate>
    </Setter>
  </ControlTheme>
</ResourceDictionary>
